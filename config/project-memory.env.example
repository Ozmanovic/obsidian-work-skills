# Copy to ~/.agents/project-memory.env and edit for your machine.

# Required for writing notes.
PROJECT_MEMORY_VAULT=

# Folder inside the vault.
PROJECT_MEMORY_WORK_ROOT=Work

# Colon-separated repo search roots. Example:
# PROJECT_MEMORY_REPO_ROOTS=$HOME/git:$HOME/work
PROJECT_MEMORY_REPO_ROOTS=$HOME/git

# Used for checkpoint filenames and autojournal bootstrap windows.
PROJECT_MEMORY_TIMEZONE=UTC

# Comma-separated local agent sources to inspect when available.
PROJECT_MEMORY_AGENT_SOURCES=codex,claude,copilot

# Optional overrides. Leave empty to use defaults.
PROJECT_MEMORY_CODEX_SESSIONS=
PROJECT_MEMORY_CLAUDE_PROJECTS=
PROJECT_MEMORY_COPILOT_WORKSPACE_STORAGE=
PROJECT_MEMORY_COPILOT_GLOBAL_STORAGE=

# Optional scheduled autojournal time.
PROJECT_MEMORY_AUTOJOURNAL_TIME=15:30
